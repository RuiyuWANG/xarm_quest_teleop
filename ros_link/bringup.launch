<launch>
  <!-- xArm -->
  <!-- Replace with your actual xarm_ros bringup include -->
  <!-- <include file="$(find xarm_bringup)/launch/xarm6_bringup.launch" /> -->

  <!-- RealSense camera(s) -->
  <!-- Hand camera -->
  <group ns="hand_cam">
    <node pkg="realsense2_camera" type="realsense2_camera_node" name="camera" output="screen">
      <param name="align_depth" value="true"/>
      <param name="enable_color" value="true"/>
      <param name="enable_depth" value="true"/>
      <param name="enable_pointcloud" value="true"/>
      <!-- serial_no if needed -->
    </node>
  </group>

  <!-- Third-person camera -->
  <group ns="third_cam">
    <node pkg="realsense2_camera" type="realsense2_camera_node" name="camera" output="screen">
      <param name="align_depth" value="true"/>
      <param name="enable_color" value="true"/>
      <param name="enable_depth" value="true"/>
      <param name="enable_pointcloud" value="true"/>
    </node>
  </group>

  <!-- Quest2ROS -->
  <!-- Replace with your actual quest2ros launch/node -->
  <!-- <include file="$(find quest2ros)/launch/quest2ros.launch"/> -->
</launch>
